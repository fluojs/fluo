{
  "name": "@fluojs-internal/tooling-benchmarks-http",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "HTTP throughput/latency benchmark: NestJS vs fluo across Fastify and Bun",
  "scripts": {
    "bench": "tsx src/run.ts",
    "build:nestjs": "tsc -p nestjs/tsconfig.json --outDir dist/nestjs && node -e \"require('fs').writeFileSync('dist/nestjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "build:fluo": "tsc src/fluo/server.ts --target ES2022 --module ESNext --moduleResolution Bundler --strict --skipLibCheck --outDir dist/fluo-fastify",
    "build:fluo:bun": "tsc src/fluo-bun/server.ts --target ES2022 --module ESNext --moduleResolution Bundler --strict --skipLibCheck --outDir dist/fluo-bun",
    "bench:fluo:bun": "pnpm run build:fluo:bun && bun run dist/fluo-bun/fluo-bun/server.js",
    "bench:fluo": "pnpm run build:fluo && node dist/fluo-fastify/fluo/server.js",
    "bench:nestjs": "pnpm run build:nestjs && node dist/nestjs/nestjs/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p nestjs/tsconfig.json"
  },
  "dependencies": {
    "@fluojs/config": "link:../../../packages/config",
    "@fluojs/core": "link:../../../packages/core",
    "@fluojs/di": "link:../../../packages/di",
    "@fluojs/http": "link:../../../packages/http",
    "@fluojs/platform-bun": "link:../../../packages/platform-bun",
    "@fluojs/platform-fastify": "link:../../../packages/platform-fastify",
    "@fluojs/runtime": "link:../../../packages/runtime",
    "@fluojs/validation": "link:../../../packages/validation",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "fastify": "^5.8.5",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/node": "^22.0.0",
    "autocannon": "^7.0.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.23.1",
    "typescript": "~5.8.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "fast-uri": "3.1.4",
      "fastify": "5.8.5",
      "find-my-way": "9.7.0",
      "form-data": "4.0.6",
      "uuid": "11.1.1"
    }
  }
}
